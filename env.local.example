# Copy to `.env.local` (never commit `.env.local` or push it to GitHub).
# File must sit next to `package.json`. After any change, stop and run `npm run dev` again.

# --- Contact form + MongoDB (required for portfolio messages) ---
# Paste the FULL string from Atlas (Connect → Drivers). Do not leave example placeholders like ... or cluster0......
# If the password contains # or & wrap the whole URL in double quotes:
# MONGO_URI="mongodb+srv://user:pass@cluster0.xxx.mongodb.net/dbname?retryWrites=true&w=majority"
MONGO_URI=
# Optional alias (same value as MONGO_URI if you prefer this name):
# MONGODB_URI=
# Gmail sender: App Password only (Account → Security → 2-Step Verification → App passwords). Not your normal Gmail password.
EMAIL_USER=
EMAIL_PASS=
# Inbox where you want contact notifications.
CONTACT_TO_EMAIL=

# --- Admin dashboard (/admin) — optional; add only if you use admin login ---
ADMIN_EMAIL=
# Bcrypt hash of your admin password, base64-encoded. Run: node encode-hash.js (after setting hash in that file) or see README in repo.
ADMIN_PASSWORD_HASH=
# Random long string for JWT (e.g. openssl rand -base64 32).
NEXTAUTH_SECRET=

# --- Supabase — optional; only if you use those features ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
